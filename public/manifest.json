{
  "manifest_version": 3,
  "name": "J-Lite",
  "version": "1.0",
  "description": "A lightweight ('lite') Jira project and issue browser",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "j-lite-ext-sw.js"
  },
  "action": {
    "default_title": "Inject JS"
  },
  "web_accessible_resources": [
    {
      "resources": ["main.js", "main.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
